{
  "name": "toggl-pilot",
  "version": "0.5.0",
  "description": "Unofficial CLI for Toggl Track time management",
  "license": "MIT",
  "author": "Stefano Locati",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/appforgelab/toggl-pilot.git",
    "name": "appforgelab/toggl-pilot"
  },
  "keywords": [
    "toggl",
    "toggl-track",
    "cli",
    "time-tracking"
  ],
  "type": "module",
  "bin": {
    "tgp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup && tsx scripts/add-shebang.ts",
    "format": "prettier --write \"**/*.{ts,md,mdx}\"",
    "format:md": "prettier --write \"**/*.{md,mdx}\"",
    "format:check": "prettier --check \"**/*.{ts,md,mdx}\"",
    "format:check:md": "prettier --check \"**/*.{md,mdx}\"",
    "lint": "eslint src",
    "lint:md": "markdownlint \"**/*.{md,mdx}\" --ignore-path .markdownlintignore",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pre-commit": "tsx scripts/pre-commit.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
