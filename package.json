{
  "name": "toggl-pilot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "track": "tsx src/index.ts track",
    "me": "tsx src/index.ts me",
    "entries": "tsx src/index.ts entries",
    "projects": "tsx src/index.ts projects",
    "delete": "tsx src/index.ts delete",
    "stop": "tsx src/index.ts stop",
    "tags": "tsx src/index.ts tags",
    "edit": "tsx src/index.ts edit",
    "format:md": "prettier --write \"**/*.{md,mdx}\"",
    "format:check:md": "prettier --check \"**/*.{md,mdx}\"",
    "lint:md": "markdownlint \"**/*.{md,mdx}\" --ignore-path .markdownlintignore",
    "typecheck": "tsc --noEmit",
    "pre-commit": "tsx scripts/pre-commit.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
